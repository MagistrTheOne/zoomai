# Скопируй в .env и заполни OPENAI_API_KEY.
# Подробности: README.md → Phase 1 Pilot

# --- OpenAI models (chained voice agent: specialized Audio APIs + Chat Completions) ---
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
STT_MODE=http_stream
# Legacy fallback only, used when STT_MODE=whisper_chunked
OPENAI_STT_WHISPER_MODEL=whisper-1
# Required only when STT_MODE=realtime_ws (manual opt-in)
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

OPENAI_STT_USE_REALTIME=0
OPENAI_STT_CHUNK_MS=1500

# VAD для STT_MODE=http_stream (PCM16 16 kHz, кадры 20 ms)
# OPENAI_STT_VAD_RMS_THRESHOLD=0.015
# OPENAI_STT_SILENCE_MS=450
# OPENAI_STT_MIN_UTTERANCE_MS=120
# OPENAI_STT_MAX_UTTERANCE_MS=28000

# --- Аудио ---
AUDIO_OUT_MODE=browser_injection
# AUDIO_OUT_MODE=virtual_mic
AUDIO_CAPTURE_WS_PORT=47001

# --- HTTP ---
PORT=3000
CONTROL_PORT=8080
MAX_CONCURRENT_SESSIONS=10
LOG_LEVEL=info
HEADLESS=1

DEBUG=false

# Docker (опционально)
# DOCKER_PATH=C:\Program Files\Docker\Docker\resources\bin\docker.exe
